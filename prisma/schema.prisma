// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  engineType = "binary"
  transpile  = true
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int       @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String    @unique
  phone          String
  password       String
  drivingLicense String?
  dateOfBirth    DateTime?
  address        String?
  city           String?
  country        String?
  isVerified     Boolean   @default(false)
  role           UserRole  @default(CUSTOMER)
  
  // Admin specific fields
  adminLevel     AdminLevel?    // For admins (super_admin, manager, staff)
  permissions    Json?          // Custom permissions for admins
  
  // Car Owner specific fields
  businessName   String?        // If owner has a business
  taxId          String?        // Business tax ID
  commission     Float?         @default(15.0) // Commission percentage for owners
  totalCars      Int?           @default(0) // Number of cars they own
  bankAccount    Json?          // Bank details for payouts
  
    // Password Reset Fields 
  resetToken     String?        @unique
   resetCode      String?
  resetTokenExpiry DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  // Relations
  bookings       Booking[]
  userProfile    UserProfile?
  payments       Payment[]
  messages       ContactMessage[]
  ownedCars      Car[]          @relation("CarOwner") // Cars owned by this user
  managedCars    Car[]          @relation("CarAdmin") // Cars managed by admin
  receivedPayments Payment[]    @relation("OwnerPayments") // Payments received as owner

  

  @@map("users")
}

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  avatar      String?
  preferences Json?
  notifications Json?  
  privacy     Json?    
  security    Json?    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
  
  @@map("user_profiles")
}

model Car {
  id          Int      @id @default(autoincrement())
  make        String
  model       String
  year        String
  price       String
  image       String
  fuelType    FuelType
  seats       Int
  transmission Transmission
  drive       DriveType
  category    CarCategory
  rating      Float
  reviews     Int
  power       String
  isAvailable Boolean  @default(true)
  location    String?
   plateNumber  String? 
  
  // Owner relation
  ownerId     Int?              // Who owns this car (car owner)
  owner       User?             @relation("CarOwner", fields: [ownerId], references: [id])
  
  // Admin relation
  managedBy   Int?              // Admin who manages this car
  admin       User?             @relation("CarAdmin", fields: [managedBy], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  bookings Booking[]
  payments Payment[]
  
  @@map("cars")
}

model Booking {
  id           Int        @id @default(autoincrement())
  userId       Int
  carId        Int
  startDate    DateTime
  endDate      DateTime
  totalPrice   Float
  status       BookingStatus @default(PENDING)
  pickupLocation  String
  dropoffLocation String
  specialRequests String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  // Relations
  user    User    @relation(fields: [userId], references: [id])
  car     Car     @relation(fields: [carId], references: [id])
  payment Payment?
  
  @@map("bookings")
}

model Payment {
  id               Int           @id @default(autoincrement())
  checkoutRequestID String        @unique
  transactionId    String        @unique
  carId            Int
  userId           Int
  bookingId        Int?           @unique
  phoneNumber      String
  amount           Float
  status           PaymentStatus @default(PENDING)
  mpesaReceiptNumber String?
  accountReference String
  transactionDesc  String
  failureReason    String?
  metadata         Json?
  
  // Commission tracking
  ownerId          Int?           // Car owner who gets paid
  ownerCommission  Float?         // Commission amount for owner
  adminCommission  Float?         // Platform commission
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  // Relations
  car    Car    @relation(fields: [carId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  owner  User?  @relation("OwnerPayments", fields: [ownerId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
  
  @@map("payments")
}

// Enums
enum UserRole {
  CUSTOMER
  AGENT        // Car Owner
  ADMIN
  SUPER_ADMIN  // Top level admin
}

enum AdminLevel {
  SUPER_ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum DriveType {
  FWD
  RWD
  AWD
  FOUR_WD
}

enum CarCategory {
  ECONOMY
  COMPACT
  MIDSIZE
  STANDARD
  FULLSIZE
  LUXURY
  SUV
  SPORTS
  MINIVAN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

model ContactMessage {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String
  subject     String
  message     String
  rentalType  String
  emailStatus  String?  @default("pending")
  createdAt   DateTime @default(now())

  agentId     Int?
  agent       Agent?   @relation(fields: [agentId], references: [id])

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  status      MessageStatus @default(UNREAD)
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
}

model Agent {
  id           Int      @id @default(autoincrement())
  name         String
  role         String
  rating       Float
  reviews      Int
  image        String
  phone        String
  email        String   @unique
  location     String
  bio          String
  specialties  String[] 
  languages    String[] 
  responseTime String
  joined       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages ContactMessage[]

  @@map("agents")
}